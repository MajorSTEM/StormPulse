APP_NAME=StormPulse
# NWS requires a User-Agent identifying your app. Use: AppName/version contact@email.com
NWS_USER_AGENT=StormPulse/1.0 your@email.com
# NOAA API key (get one free at https://www.ncdc.noaa.gov/cdo-web/token)
NOAA_API_KEY=your_noaa_api_key_here
INGEST_INTERVAL_SECONDS=300
DATABASE_URL=sqlite+aiosqlite:///./stormpulse.db
# Add your deployed frontend URL once live, e.g. https://stormpulse.vercel.app
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002"]
